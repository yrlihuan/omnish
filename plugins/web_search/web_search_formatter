#!/usr/bin/env bash
# web_search_formatter - External formatter for web_search plugin.
#
# Protocol: newline-delimited JSON on stdin/stdout (long-running).
# Input:  {"formatter":"...","tool_name":"...","params":{...},"output":"...","is_error":bool}
# Output: {"summary":"...","compact":[...],"full":[...]}
#
# Strips HTML tags from search result descriptions.
# Compact: first 5 results as "N. [Title](URL)", then (+N more results).
# Full:    first 5 results as "N. [Title](URL)\n  Description", then (+N more results).

PROG=$(cat <<'JQEOF'
def strip_html:
    gsub("<[^>]*>"; "")
  | gsub("&amp;"; "&")
  | gsub("&lt;"; "<")
  | gsub("&gt;"; ">")
  | gsub("&quot;"; "\"")
  | gsub("&#39;"; "'")
  | gsub("&apos;"; "'")
  | gsub("&nbsp;"; " ")
  | gsub("  +"; " ");

def trim: sub("^\\s+"; "") | sub("\\s+$"; "");

def parse_lines($lines):
  ($lines | reduce .[] as $line (
    {results: [], cur_title: null, cur_desc: ""};
    if ($line | test("^\\s*[0-9]+\\.\\s+\\[")) then
      (if .cur_title != null then
         .results + [{title: .cur_title, desc: (.cur_desc | trim)}]
       else .results end) as $res
      | {results: $res,
         cur_title: ($line | sub("^\\s*[0-9]*\\.\\s*"; "")),
         cur_desc: ""}
    elif .cur_title != null and $line != "" then
      .cur_desc as $d
      | .cur_desc = (if $d == "" then $line else "\($d) \($line)" end)
    else
      .
    end
  )) as $state
  | if $state.cur_title != null then
      $state.results + [{title: $state.cur_title, desc: ($state.cur_desc | trim)}]
    else $state.results end;

def fmt:
  if .is_error then
    .output as $o | {summary: $o, compact: [$o], full: [$o]}
  else
    (.output | strip_html) as $cleaned
    | parse_lines($cleaned | split("\n")) as $results
    | ($results | length) as $count
    | 5 as $MAX
    | if $count == 0 then
        {summary: $cleaned, compact: [$cleaned], full: [$cleaned]}
      else
        ([$count, $MAX] | min) as $show
        | ([range($show)] | map("\(. + 1). \($results[.].title)")) as $compact_main
        | ([range($show)] | map(
            "\(. + 1). \($results[.].title)",
            (if $results[.].desc != "" then "   \($results[.].desc)" else empty end)
          )) as $full_main
        | (if $count > $MAX
           then ["(+\($count - $MAX) more results)"]
           else [] end) as $more
        | {summary: null,
           compact: ($compact_main + $more),
           full:    ($full_main    + $more)}
      end
  end;

inputs | fmt
JQEOF
)
exec jq -cn --unbuffered "$PROG"
