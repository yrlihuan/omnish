#!/usr/bin/env bash
# web_fetch_formatter - External formatter for web_fetch plugin.
#
# Protocol: newline-delimited JSON on stdin/stdout (long-running).
# Input:  {"formatter":"...","tool_name":"...","params":{...},"output":"...","is_error":bool}
# Output: {"summary":"...","compact":[...],"full":[...]}
#
# Compact: title + URL + content line count
# Full:    title + URL + first N lines of content

set -uo pipefail

MAX_LINES=30

TMPFILE=$(mktemp)
trap 'rm -f "$TMPFILE"' EXIT

while IFS= read -r line; do
    # Write input line to temp file to avoid ARG_MAX with large output
    echo "$line" > "$TMPFILE"
    output=$(jq -r '.output // ""' < "$TMPFILE")
    is_error=$(jq -r '.is_error // false' < "$TMPFILE")

    if [ "$is_error" = "true" ]; then
        echo "$output" | jq -Rsc '{"summary": ., "compact": [.], "full": [.]}'
        continue
    fi

    # Extract title (first line starting with "# ")
    title=$(echo "$output" | head -1 | sed 's/^# //')
    # Extract URL line
    url_line=$(echo "$output" | sed -n '2p')

    # Count total content lines (skip title + URL + blank line)
    total_lines=$(echo "$output" | tail -n +4 | wc -l)

    # Build compact JSON array
    compact_json=$(
        {
            [ -n "$title" ] && echo "$title"
            echo "$url_line" | grep -q '^URL: ' && echo "$url_line"
            echo "($total_lines lines)"
        } | jq -R . | jq -sc .
    )

    # Build full JSON array
    full_json=$(
        {
            [ -n "$title" ] && echo "$title"
            echo "$url_line" | grep -q '^URL: ' && echo "$url_line"
            echo ""
            echo "$output" | tail -n +4 | head -n "$MAX_LINES"
            if [ "$total_lines" -gt "$MAX_LINES" ]; then
                remaining=$((total_lines - MAX_LINES))
                printf '\033[2;90m(+%d more lines)\033[0m' "$remaining"
            fi
        } | jq -R . | jq -sc .
    )

    # Output JSON — use --argjson to pass pre-built arrays
    jq -cn --argjson compact "$compact_json" --argjson full "$full_json" \
        '{"summary": null, "compact": $compact, "full": $full}'
done
