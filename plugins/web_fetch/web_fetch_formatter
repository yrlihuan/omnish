#!/usr/bin/env bash
# web_fetch_formatter - External formatter for web_fetch plugin.
#
# Protocol: newline-delimited JSON on stdin/stdout (long-running).
# Input:  {"formatter":"...","tool_name":"...","params":{...},"output":"...","is_error":bool}
# Output: {"summary":"...","compact":[...],"full":[...]}
#
# Compact: title + URL + content line count
# Full:    title + URL + first 30 lines of content

PROG=$(cat <<'JQEOF'
def fmt:
  if .is_error then
    (.output + "\n") as $o | {summary: $o, compact: [$o], full: [$o]}
  else
    (.output | split("\n")) as $lines
    | (($lines[0] // "") | sub("^# "; "")) as $title
    | ($lines[1] // "") as $url_line
    | ($url_line | test("^URL: ")) as $has_url
    | ([0, ($lines | length) - 3] | max) as $total
    | 30 as $max
    | {
        summary: null,
        compact: [
          (if $title != "" then $title else empty end),
          (if $has_url then $url_line else empty end),
          "(\($total) lines)"
        ],
        full: (
          [ (if $title != "" then $title else empty end)
          , (if $has_url then $url_line else empty end)
          , ""
          ]
          + $lines[3:3+$max]
          + (if $total > $max
             then ["[2;90m(+\($total - $max) more lines)[0m"]
             else [] end)
        )
      }
  end;

inputs | fmt
JQEOF
)
exec jq -cn --unbuffered "$PROG"
