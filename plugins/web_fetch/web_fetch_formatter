#!/usr/bin/env bash
# web_fetch_formatter - External formatter for web_fetch plugin.
#
# Protocol: newline-delimited JSON on stdin/stdout (long-running).
# Input:  {"formatter":"...","tool_name":"...","params":{...},"output":"...","is_error":bool}
# Output: {"summary":"...","compact":[...],"full":[...]}
#
# Compact: title + URL + content line count
# Full:    title + URL + first N lines of content

set -uo pipefail

MAX_LINES=30

while IFS= read -r line; do
    output=$(echo "$line" | jq -r '.output // ""')
    is_error=$(echo "$line" | jq -r '.is_error // false')

    if [ "$is_error" = "true" ]; then
        jq -cn --arg o "$output" '{"summary": $o, "compact": [$o], "full": [$o]}'
        continue
    fi

    # Extract title (first line starting with "# ")
    title=$(echo "$output" | head -1 | sed 's/^# //')
    # Extract URL line
    url_line=$(echo "$output" | sed -n '2p')

    # Count total content lines (skip title + URL + blank line)
    total_lines=$(echo "$output" | tail -n +4 | wc -l)

    # Build compact: title + URL + line count
    compact_lines=()
    if [ -n "$title" ]; then
        compact_lines+=("$title")
    fi
    if echo "$url_line" | grep -q '^URL: '; then
        compact_lines+=("$url_line")
    fi
    compact_lines+=("($total_lines lines)")

    # Build full: title + URL + first MAX_LINES of content
    full_lines=()
    if [ -n "$title" ]; then
        full_lines+=("$title")
    fi
    if echo "$url_line" | grep -q '^URL: '; then
        full_lines+=("$url_line")
    fi
    full_lines+=("")

    # Read first MAX_LINES of content
    content_preview=$(echo "$output" | tail -n +4 | head -n "$MAX_LINES")
    while IFS= read -r cline; do
        full_lines+=("$cline")
    done <<< "$content_preview"

    if [ "$total_lines" -gt "$MAX_LINES" ]; then
        remaining=$((total_lines - MAX_LINES))
        full_lines+=("(+${remaining} more lines)")
    fi

    # Output JSON
    jq -cn --jsonargs \
        '{"summary": null, "compact": $ARGS.positional[0], "full": $ARGS.positional[1]}' \
        "$(printf '%s\n' "${compact_lines[@]}" | jq -R . | jq -s .)" \
        "$(printf '%s\n' "${full_lines[@]}" | jq -R . | jq -s .)"
done
